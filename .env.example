# --- Supabase ---
# From your Supabase dashboard: Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Ingest auth ---
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INGEST_TOKEN=

# --- GitHub ---
# Personal Access Token. Needs the `repo` scope to read PRIVATE repos and to
# lift the 60-req/hr anon rate limit (required for auto-sync). Classic PAT:
#   github.com/settings/tokens  → "repo" scope
GITHUB_TOKEN=
GITHUB_USERNAME=vatsal-agra
# Background sync cadence in minutes (0 = off, 1440 = daily). Only runs when
# GITHUB_TOKEN is set. The owner can also pull on demand via the Refresh button.
GITHUB_SYNC_MINUTES=1440

# --- Server ---
PORT=8787
# Cross-origin browser allowlist (comma-separated). localhost dev origins are
# always allowed; set your deployed domain here, e.g.:
#   ALLOWED_ORIGINS=https://your-site.netlify.app
ALLOWED_ORIGINS=
