# --- Supabase ---
# From your Supabase dashboard: Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Ingest auth ---
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INGEST_TOKEN=

# --- GitHub ---
# Personal Access Token. Needs the `repo` scope to read PRIVATE repos and to
# lift the 60-req/hr anon rate limit (required for auto-sync). Classic PAT:
#   github.com/settings/tokens  → "repo" scope
GITHUB_TOKEN=
GITHUB_USERNAME=vatsal-agra
# Background sync cadence in minutes (0 = off). Only runs when GITHUB_TOKEN is
# set. Discovers new repos + pulls new commits/releases automatically.
GITHUB_SYNC_MINUTES=30

# --- Server ---
PORT=8787
